# Copie para .env e ajuste os valores.

# Banco PostgreSQL. Local: um Postgres na sua maquina. Producao (Render):
# use a "Internal Database URL" do Postgres gerenciado.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fluxo?schema=public"

# Segredo de assinatura da sessao (JWT). Use um valor longo e aleatorio.
AUTH_SECRET="troque-por-um-valor-longo-e-aleatorio"
