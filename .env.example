# Copie para .env e ajuste os valores.

# Banco SQLite local.
DATABASE_URL="file:./prisma/dev.db"

# Segredo de assinatura da sessao (JWT). Use um valor longo e aleatorio.
AUTH_SECRET="troque-por-um-valor-longo-e-aleatorio"

# URL base usada nos links das notificacoes.
APP_BASE_URL="http://localhost:3000"

# Configure quando a conta WhatsApp Business estiver pronta.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TEMPLATE_NAME=""
