{
  "name": "fluxo",
  "version": "1.0.0",
  "description": "Sistema de aprovacao de fluxo financeiro",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "build": "next build",
    "start": "npm run db:setup && next start",
    "lint": "eslint .",
    "check:finance": "tsx scripts/check-finance-management.ts",
    "check:migration": "node scripts/check-migration.mjs",
    "prisma:generate": "prisma generate",
    "db:setup": "npm run db:migrate:deploy && npm run db:seed",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed"
  },
  "keywords": [
    "financeiro",
    "aprovacao",
    "workflow"
  ],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
